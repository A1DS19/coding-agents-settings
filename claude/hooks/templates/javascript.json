{
  "_comment": "Per-project hooks for JavaScript/TypeScript projects. Copy this file to .claude/settings.json in your repo.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [{"type": "command", "command": "npx eslint --fix $CLAUDE_FILE_PATH 2>&1 || true"}]
      },
      {
        "matcher": "Write",
        "hooks": [{"type": "command", "command": "npx prettier --write $CLAUDE_FILE_PATH 2>&1 || true"}]
      }
    ]
  }
}
